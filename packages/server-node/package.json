{
  "name": "@hari7261/ainative-server-node",
  "version": "0.2.4",
  "description": "AINative Node.js server adapter",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "express": "^4.18.3",
    "cors": "^2.8.5",
    "openai": "^4.28.4",
    "@anthropic-ai/sdk": "^0.17.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "tsup": "^8.0.2",
    "vitest": "^1.4.0"
  },
  "keywords": [
    "ai",
    "llm",
    "server",
    "nodejs",
    "express"
  ],
  "author": "AINative Contributors",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
