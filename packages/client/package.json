{
  "name": "@hari7261/ainative-client",
  "version": "0.1.0",
  "description": "AINative client runtime for building AI-driven UIs",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "tsup": "^8.0.2",
    "vitest": "^1.4.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "keywords": [
    "ai",
    "llm",
    "react",
    "streaming",
    "multimodal"
  ],
  "author": "AINative Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hari7261/ainative.git",
    "directory": "packages/client"
  }
}
